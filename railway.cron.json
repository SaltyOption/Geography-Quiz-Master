{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "echo 'install-only: the cron start command runs the script via tsx'"
  },
  "deploy": {
    "startCommand": "pnpm --filter @workspace/scripts run check-db-image-files",
    "cronSchedule": "0 6 * * *",
    "restartPolicyType": "NEVER"
  }
}
